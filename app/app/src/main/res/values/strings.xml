    <string name="audit_check_tun_interface_title">TUN interface is visible in /sys/class/net</string>
    <string name="audit_check_tun_interface_detail">A tun0 interface is listed and can be enumerated by any app with filesystem access.</string>
    <string name="audit_check_tun_interface_remediation">Enable SELinux policy to restrict /sys/class/net enumeration from untrusted apps.</string>
    <string name="audit_check_not_vpn_capability_title">NOT_VPN capability set on active network</string>
    <string name="audit_check_not_vpn_capability_detail">ConnectivityManager reports NOT_VPN for the default network, hiding proxy presence.</string>
    <string name="audit_check_not_vpn_capability_remediation">No action required.</string>
    <string name="audit_check_api_port_protected_title">Local control ports are protected</string>
    <string name="audit_check_api_port_protected_detail">Production mode keeps the Clash API disabled; any enabled local control ports are root/core protected.</string>
    <string name="audit_check_api_port_protected_remediation">No action required.</string>
    <string name="audit_check_dns_leak_title">DNS queries may leak to system resolver</string>
    <string name="audit_check_dns_leak_detail">Some queries bypass PrivStack DNS and reach the ISP resolver directly.</string>
    <string name="audit_check_dns_leak_remediation">Keep DNS interception enabled for proxied apps and route their DNS through the configured remote resolver.</string>
    <string name="audit_check_package_visibility_title">Proxy package visible to other apps</string>
    <string name="audit_check_package_visibility_detail">Apps can query PackageManager and discover the proxy app is installed.</string>
    <string name="audit_check_package_visibility_remediation">Use a randomized package name or enable Android 11+ package visibility filtering.</string>
    <string name="audit_check_iptables_loop_safe_title">iptables rules prevent routing loops</string>
    <string name="audit_check_iptables_loop_safe_detail">OUTPUT chain marks daemon packets to skip re-routing through PrivStack.</string>
    <string name="audit_check_iptables_loop_safe_remediation">No action required.</string>
    <string name="audit_check_proc_net_leak_title">/proc/net exposes proxy connections</string>
    <string name="audit_check_proc_net_leak_detail">tcp/tcp6 files show the SOCKS inbound port, detectable by other apps.</string>
    <string name="audit_check_proc_net_leak_remediation">Apply SELinux policy to restrict /proc/net reads from third-party apps.</string>
    <string name="audit_check_ipv6_rules_mirror_title">IPv6 iptables rules mirror IPv4</string>
    <string name="audit_check_ipv6_rules_mirror_detail">ip6tables rules are consistent with iptables, preventing IPv6 bypass.</string>
    <string name="audit_check_ipv6_rules_mirror_remediation">No action required.</string>
    <string name="audit_check_icmp_handling_title">ICMP follows the proxy routing policy</string>
    <string name="audit_check_icmp_handling_detail">Ping traffic is captured and routed correctly.</string>
    <string name="audit_check_icmp_handling_remediation">No action required.</string>
    <string name="audit_check_selinux_status_title">SELinux is enforcing</string>
    <string name="audit_check_selinux_status_detail">SELinux is in enforcing mode with daemon-specific policy loaded.</string>
    <string name="audit_check_selinux_status_remediation">No action required.</string>
    <string name="audit_check_module_integrity_title">Kernel module hashes verified</string>
    <string name="audit_check_module_integrity_detail">privd, privctl, and sing-box match expected SHA-256 digests.</string>
    <string name="audit_check_module_integrity_remediation">No action required.</string>
    <string name="audit_check_private_dns_unchanged_title">Private DNS was modified by daemon</string>
    <string name="audit_check_private_dns_unchanged_detail">The system Private DNS setting was changed, which apps can detect.</string>
    <string name="audit_check_private_dns_unchanged_remediation">Restore the original Private DNS setting and route DNS at the iptables level instead.</string>
    <string name="audit_check_network_change_handler_title">Network change listener active</string>
    <string name="audit_check_network_change_handler_detail">The daemon re-establishes routes and DNS after connectivity changes.</string>
    <string name="audit_check_network_change_handler_remediation">No action required.</string>


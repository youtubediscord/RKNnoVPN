    <string name="advisor_setup_guide_title">Work Profile Setup Guide</string>
    <string name="advisor_setup_guide_subtitle">Isolate sensitive apps from proxy detection</string>
    <string name="advisor_setup_guide_show">Setup Guide</string>
    <string name="advisor_setup_guide_hide">Hide Guide</string>
    <string name="advisor_setup_step_1">1. Install Shelter or Island from F-Droid or Play Store.</string>
    <string name="advisor_setup_step_2">2. Create a Work Profile when the app prompts you.</string>
    <string name="advisor_setup_step_3">3. Clone banking and government apps into the Work Profile.</string>
    <string name="advisor_setup_step_4">4. Do not install the proxy or VPN app inside the Work Profile.</string>
    <string name="advisor_setup_step_5">5. Apps inside the Work Profile will use the system direct connection and stay isolated from PrivStack-routed apps in the Personal profile.</string>
    <string name="advisor_setup_step_6">6. Verify by opening a banking app in the Work Profile. It should stop detecting a VPN.</string>
    <string name="advisor_setup_tip">Tip: Shelter is open-source and lightweight. It creates a standard Android Work Profile without requiring device owner or root.</string>
